# Domain used by Caddy. Use a real domain for automatic HTTPS, e.g. diary.example.com
SITE_DOMAIN=localhost

# Public URL used by the API when returning uploaded image URLs.
# For production, use https://your-domain
PUBLIC_BASE_URL=http://localhost

# PostgreSQL
POSTGRES_USER=tietie
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=tietie_diary
DATABASE_URL=postgres://tietie:change-this-password@postgres:5432/tietie_diary

# API
JWT_SECRET=change-this-long-random-secret
STORAGE_DIR=/app/storage

# AI provider configuration, filled later
AI_PROVIDER=
AI_API_KEY=
