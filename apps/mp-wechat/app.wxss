page {
  min-height: 100%;
  background: #fff8df;
  color: #263447;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  border-radius: 8px;
  font-weight: 800;
}

.page {
  padding: 28rpx 28rpx 48rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border: 4rpx solid #2f6ea3;
  border-radius: 16rpx;
  background: #fffdf4;
  box-shadow: 8rpx 8rpx 0 rgba(47, 110, 163, 0.16);
}

.eyebrow {
  color: #2f6ea3;
  font-size: 24rpx;
  font-weight: 900;
}

.title {
  margin-top: 10rpx;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.16;
}

.copy {
  margin-top: 14rpx;
  color: #667789;
  font-size: 28rpx;
  line-height: 1.7;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 24rpx;
}

.primary,
.secondary {
  min-height: 84rpx;
  padding: 0 24rpx;
  border: 4rpx solid #2f6ea3;
}

.primary {
  background: #ffcf56;
}

.secondary {
  background: #ffffff;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.section-title text {
  color: #667789;
  font-size: 24rpx;
}

.diary-row {
  display: grid;
  grid-template-columns: 132rpx 1fr;
  gap: 20rpx;
  padding: 18rpx;
  border: 4rpx solid rgba(47, 110, 163, 0.34);
  border-radius: 16rpx;
  background: #ffffff;
}

.diary-row + .diary-row {
  margin-top: 16rpx;
}

.thumb {
  width: 132rpx;
  height: 132rpx;
  border-radius: 14rpx;
  background: #ffcf56;
}

.row-body {
  min-width: 0;
}

.row-title {
  font-size: 28rpx;
  font-weight: 900;
}

.row-copy {
  margin-top: 8rpx;
  color: #667789;
  font-size: 24rpx;
  line-height: 1.5;
}

.field {
  display: block;
  margin-top: 20rpx;
  color: #516070;
  font-size: 26rpx;
  font-weight: 800;
}

.input,
.textarea,
.select {
  width: 100%;
  min-height: 84rpx;
  margin-top: 10rpx;
  padding: 18rpx;
  border: 4rpx solid rgba(47, 110, 163, 0.44);
  border-radius: 16rpx;
  background: #ffffff;
  color: #263447;
}

.textarea {
  min-height: 220rpx;
}
