page {
  min-height: 100%;
  background: #eaf7ff;
  color: #18324a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  border-radius: 14px;
  font-weight: 800;
}

.page {
  padding: 28rpx 28rpx 48rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(38, 119, 176, 0.14);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 22rpx 48rpx rgba(24, 96, 144, 0.12);
}

.eyebrow {
  color: #0c6fba;
  font-size: 24rpx;
  font-weight: 900;
}

.title {
  margin-top: 10rpx;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.16;
}

.copy {
  margin-top: 14rpx;
  color: #5b7892;
  font-size: 28rpx;
  line-height: 1.7;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 24rpx;
}

.primary,
.secondary {
  min-height: 84rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(38, 119, 176, 0.14);
}

.primary {
  background: linear-gradient(135deg, #24a8ff, #198de8);
  color: #ffffff;
}

.secondary {
  background: #ffffff;
  color: #198de8;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.section-title text {
  color: #5b7892;
  font-size: 24rpx;
}

.diary-row {
  display: grid;
  grid-template-columns: 132rpx 1fr;
  gap: 20rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(38, 119, 176, 0.14);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(24, 96, 144, 0.08);
}

.diary-row + .diary-row {
  margin-top: 16rpx;
}

.thumb {
  width: 132rpx;
  height: 132rpx;
  border-radius: 24rpx;
  background: #fff4bf;
}

.row-body {
  min-width: 0;
}

.row-title {
  font-size: 28rpx;
  font-weight: 900;
}

.row-copy {
  margin-top: 8rpx;
  color: #5b7892;
  font-size: 24rpx;
  line-height: 1.5;
}

.field {
  display: block;
  margin-top: 20rpx;
  color: #5b7892;
  font-size: 26rpx;
  font-weight: 800;
}

.input,
.textarea,
.select {
  width: 100%;
  min-height: 84rpx;
  margin-top: 10rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(38, 119, 176, 0.18);
  border-radius: 20rpx;
  background: #ffffff;
  color: #18324a;
}

.textarea {
  min-height: 220rpx;
}
