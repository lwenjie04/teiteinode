.full-button {
  width: 100%;
  margin-top: 18rpx;
}

.inline-actions {
  display: grid;
  grid-template-columns: 1fr 168rpx;
  gap: 16rpx;
  align-items: end;
}

.inline-input,
.inline-button {
  margin-top: 18rpx;
}

.inline-button {
  min-height: 84rpx;
  line-height: 84rpx;
}

.hint,
.sync-message {
  margin-top: 16rpx;
  color: #667789;
  font-size: 24rpx;
  line-height: 1.55;
}

.sync-message {
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(47, 110, 163, 0.08);
  color: #263447;
}

.danger {
  border-color: #cf5a4f;
  color: #cf5a4f;
}
