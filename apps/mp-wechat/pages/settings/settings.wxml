<view class="page">
  <view class="card">
    <text class="eyebrow">Sync</text>
    <view class="title">同步设置</view>
    <view class="copy">小程序端可以先本地记录，登录后再和自己的后端同步。</view>
  </view>

  <view class="card">
    <view class="section-title">后端地址<text>API</text></view>
    <input class="input" value="{{apiBase}}" bindinput="onApiBaseInput" placeholder="http://127.0.0.1:4000/api" />
    <button class="secondary full-button" disabled="{{syncing}}" bindtap="saveApiBase">保存地址</button>
    <view class="hint">真机调试时请改成电脑局域网 IP 或正式 HTTPS 域名。</view>
  </view>

  <view class="card">
    <view class="section-title">账号<text wx:if="{{loggedIn}}">{{userEmail}}</text><text wx:else>未登录</text></view>
    <block wx:if="{{!loggedIn}}">
      <input class="input" value="{{email}}" bindinput="onEmailInput" placeholder="邮箱" />
      <view class="inline-actions">
        <input class="input inline-input" value="{{code}}" bindinput="onCodeInput" placeholder="6 位验证码" />
        <button class="secondary inline-button" disabled="{{syncing}}" bindtap="sendCode">获取</button>
      </view>
      <button class="primary full-button" disabled="{{syncing}}" bindtap="login">登录</button>
      <view wx:if="{{devCode}}" class="hint">开发验证码：{{devCode}}</view>
    </block>
    <block wx:else>
      <button class="secondary full-button" disabled="{{syncing}}" bindtap="logout">退出登录</button>
    </block>
  </view>

  <view class="card">
    <view class="section-title">云同步<text>{{count}} 篇</text></view>
    <view class="actions">
      <button class="primary" disabled="{{syncing || !loggedIn}}" bindtap="syncBoth">双向同步</button>
      <button class="secondary" disabled="{{syncing || !loggedIn}}" bindtap="syncPush">仅上传</button>
      <button class="secondary" disabled="{{syncing || !loggedIn}}" bindtap="syncPull">仅拉取</button>
    </view>
    <view wx:if="{{message}}" class="sync-message">{{message}}</view>
  </view>

  <view class="card">
    <view class="section-title">本地数据<text>{{count}} 篇</text></view>
    <button class="secondary full-button danger" disabled="{{syncing}}" bindtap="clearLocal">清空本地</button>
  </view>
</view>
